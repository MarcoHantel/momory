# =========================

# Angular / Node / Vite .gitignore

# =========================

# Node dependencies

node_modules/

# Build output

dist/
build/
.angular/
out-tsc/

# Environment files (können Secrets enthalten!)

.env
.env.local
.env.*.local

# Logs

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files

.DS_Store
Thumbs.db

# IDEs & Editors

.vscode/
.idea/
*.swp
*.swo

# Angular cache

.cache/

# Test output

coverage/

# Optional: Firebase / Hosting (falls genutzt)

.firebase/

# Optional: Mac hidden files

.AppleDouble
.LSOverride
